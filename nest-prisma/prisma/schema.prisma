generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model consumed_foods {
  id           String    @id @db.VarChar(255)
  quantity     Decimal   @db.Decimal(10, 2)
  food_id      String    @db.VarChar(255)
  daily_log_id String    @db.VarChar(255)
  createat     DateTime? @default(now()) @db.Timestamp(6)
  daily_log    daily_log @relation(fields: [daily_log_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_daily_log")
  foods        foods     @relation(fields: [food_id], references: [id], onUpdate: NoAction, map: "fk_food")
}

model daily_log {
  id             String           @id @db.VarChar(255)
  log_date       DateTime         @db.Date
  total_calories Int?             @default(0)
  user_id        String           @db.VarChar(255)
  createat       DateTime?        @default(now()) @db.Timestamp(6)
  consumed_foods consumed_foods[]
  users          users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")
}

model foods {
  id             String           @id @db.VarChar(255)
  food_name      String           @db.VarChar(255)
  calories       Int
  category       String           @db.VarChar(255)
  createat       DateTime?        @default(now()) @db.Timestamp(6)
  consumed_foods consumed_foods[]
}

model users {
  id        String      @id @db.VarChar(255)
  username  String      @db.VarChar(255)
  createat  DateTime?   @default(now()) @db.Timestamp(6)
  daily_log daily_log[]
}
